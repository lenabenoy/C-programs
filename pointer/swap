// Online C compiler to run C program online
#include <stdio.h>
void swap(int *a,int *b)
{
    int temp;
    temp=*a;
    *a=*b;
    *b=temp;
}

int main() {
    // Write C code here
    int x,y;
    printf("enter two numbers");
    scanf("%d%d",&x,&y);
    swap(&x,&y);
    printf("after swapping:%d%d",x,y);

    return 0;
}