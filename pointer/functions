
#include <stdio.h>

// Function to find largest element
int findLargest(int *arr, int n) {
    int max = *arr;
    for(int i = 1; i < n; i++) {
        if(*(arr + i) > max)
            max = *(arr + i);
    }
    return max;
}

// Function to count even numbers
int countEven(int *arr, int n) {
    int count = 0;
    for(int i = 0; i < n; i++) {
        if(*(arr + i) % 2 == 0)
            count++;
    }
    return count;
}

// Function to reverse array
void reverse(int *arr, int n) {
    int temp;
    for(int i = 0; i < n/2; i++) {
        temp = *(arr + i);
        *(arr + i) = *(arr + n - i - 1);
        *(arr + n - i - 1) = temp;
    }
}

int main() {
    int n, arr[100];

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    printf("Largest = %d\n", findLargest(arr, n));
    printf("Even count = %d\n", countEven(arr, n));

    reverse(arr, n);

    printf("Reversed array:\n");
    for(int i = 0; i < n; i++)
        printf("%d ", *(arr + i));

    return 0;
}