// Online C compiler to run C program online
#include <stdio.h>
int factorial(int n)
{
    if(n==0||n==1)
    return 1;
    else
    return n*factorial(n-1);
}

int main() {
    // Write C code here
    int n;
    printf("enter the limit");
    scanf("%d",&n);
    printf("factorial=%d",factorial(n));

    return 0;
}