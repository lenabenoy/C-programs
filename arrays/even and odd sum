#include <stdio.h>
void findsum(int arr[],int n)
{
int i,evensum=0,oddsum=0;
{
    for(i=0;i<n;i++)
    {
    if(arr[i]%2==0)
    evensum+=arr[i];
    else
    oddsum+=arr[i];
    }
    printf("sum of even=%d",evensum);
    printf("sum of odd=%d",oddsum);
    }
    
}

